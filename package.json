{
  "name": "steam-json-bourne",
  "version": "1.0.0",
  "description": "GitHub Action to fetch Steam gameplay data as JSON — playtime snapshots, daily deltas, and recently played games with artwork",
  "main": "src/index.js",
  "scripts": {
    "build": "esbuild src/index.js --bundle --platform=node --target=node20 --outfile=dist/index.js",
    "test": "node --test src/index.test.js"
  },
  "keywords": [
    "github-action",
    "steam",
    "gaming",
    "playtime"
  ],
  "author": "ggfevans",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.10.1"
  },
  "devDependencies": {
    "esbuild": "^0.27.3"
  }
}
